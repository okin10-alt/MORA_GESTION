# FORMA — .htaccess
# Colocar en la raíz del subdominio

Options -Indexes
ServerSignature Off

# ── Seguridad básica ───────────────────────────────────────
<FilesMatch "\.(sql|log|env|json|md)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Proteger carpeta api/ excepto los endpoints públicos
<FilesMatch "^(config|db)\.php$">
  Order allow,deny
  Deny from all
</FilesMatch>

# ── HTTPS forzado ──────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Cache estáticos ────────────────────────────────────────
<FilesMatch "\.(css|js|woff2|png|jpg|svg|ico)$">
  Header set Cache-Control "max-age=2592000, public"
</FilesMatch>

# ── Sin cache en HTML y PHP ────────────────────────────────
<FilesMatch "\.(html|php)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# ── Comprimir respuestas ───────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── PHP: ocultar errores en producción ────────────────────
<IfModule mod_php.c>
  php_flag display_errors Off
  php_flag log_errors On
</IfModule>
